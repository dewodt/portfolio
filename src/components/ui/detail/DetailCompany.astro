---
import BuildingIcon from "@/components/icons/BuildingIcon.astro";

interface Props {
  company: string;
}

const { company } = Astro.props;
---

<span
  class="text-muted-foreground inline-flex items-center gap-1.5 font-mono text-xs tracking-widest uppercase lg:text-sm"
>
  <BuildingIcon class="size-3.5 shrink-0 lg:size-4" />
  {company}
</span>
