---
import { Image } from "astro:assets";

interface Props {
  name: string;
  imageUrl?: string | null;
  profileUrl: string;
}

const { name, imageUrl, profileUrl } = Astro.props;

const initials = name
  .replace(/^@/, "")
  .split(/[\s.-]+/)
  .map((part) => part[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();

const fallbackSvg = `data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2728%27 height=%2728%27 viewBox=%270 0 28 28%27%3E%3Ccircle cx=%2714%27 cy=%2714%27 r=%2714%27 fill=%27%236b7280%27/%3E%3Ctext x=%2714%27 y=%2718%27 text-anchor=%27middle%27 font-size=%2712%27 font-family=%27system-ui,sans-serif%27 font-weight=%27600%27 fill=%27white%27%3E${initials}%3C/text%3E%3C/svg%3E`;
---

<a
  href={profileUrl}
  target="_blank"
  rel="noreferrer"
  class="group text-muted-foreground hover:text-foreground inline-flex items-center gap-2.5 text-sm transition-colors lg:text-base"
>
  {
    imageUrl ? (
      <span
        class="size-7 shrink-0 rounded-full bg-cover bg-center lg:size-8"
        style={`background-image: url('${fallbackSvg}')`}
      >
        <Image
          src={imageUrl}
          alt={name}
          width={256}
          height={256}
          widths={[128, 192, 256]}
          sizes="(max-width: 1023px) 28px, 32px"
          loading="eager"
          style="display:none"
          class="size-full rounded-full object-cover"
          onload={`this.style.display='block'`}
          onerror={`this.onerror=null;this.style.display='none'`}
        />
      </span>
    ) : (
      <img
        src={fallbackSvg}
        alt={name}
        class="size-7 shrink-0 rounded-full object-cover lg:size-8"
      />
    )
  }
  <span class="font-mono font-medium underline-offset-4 group-hover:underline">
    {name}
  </span>
</a>
