---
import MapPinIcon from "@/components/icons/MapPinIcon.astro";

interface Props {
  location: string;
}

const { location } = Astro.props;
---

<span
  class="text-muted-foreground inline-flex items-center gap-1.5 font-mono text-xs tracking-widest uppercase lg:text-sm"
>
  <MapPinIcon class="size-3.5 shrink-0 lg:size-4" />
  {location}
</span>
