---
import TrophyIcon from "@/components/icons/TrophyIcon.astro";

interface Props {
  issuer: string;
}

const { issuer } = Astro.props;
---

<span
  class="text-muted-foreground inline-flex items-center gap-1.5 font-mono text-xs tracking-widest uppercase lg:text-sm"
>
  <TrophyIcon class="size-3.5 shrink-0 lg:size-4" />
  {issuer}
</span>
