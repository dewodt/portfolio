---
import type { AllExperienceCompaniesQueryResult } from "@/types/sanity";
import CardDescription from "./shared/CardDescription.astro";
import CardMetaDateRange from "./shared/CardMetaDateRange.astro";
import CardMetaEmploymentType from "./shared/CardMetaEmploymentType.astro";
import CardMetaLocation from "./shared/CardMetaLocation.astro";
import CardMonoLabel from "./shared/CardMonoLabel.astro";
import CardPills from "./shared/CardPills.astro";
import CardThumbnail from "./shared/CardThumbnail.astro";
import CardTitle from "./shared/CardTitle.astro";
import MetaSeparator from "../shared/MetaSeparator.astro";

interface Props {
  experience: AllExperienceCompaniesQueryResult[number];
}

const { experience } = Astro.props;
const isSingleRole = experience.roles.length === 1;
const role = experience.roles[0];
---

<article
  class="group/card border-border bg-card hover:drop-shadow-primary-sm relative overflow-hidden rounded-xl border transition-all duration-300 hover:-translate-y-1"
>
  <div
    class="bg-primary/0 group-hover/card:bg-primary/10 dark:group-hover/card:bg-primary/15 pointer-events-none absolute -inset-px -z-10 rounded-xl blur-xl transition-all duration-500"
  >
  </div>

  {
    isSingleRole && role && (
      <a
        href={`/experiences/${role.slug.current}`}
        aria-label={`Link to ${role.title} at ${experience.company}`}
        class="absolute inset-0 z-30"
      />
    )
  }

  <div class="flex gap-3 p-4 lg:gap-4">
    {/* Company image thumbnail */}
    <CardThumbnail src={experience.image.url!} alt={experience.image.alt} />

    {/* Content */}
    <div class="flex flex-1 flex-col">
      {/* Company mono label */}
      <CardMonoLabel>{experience.company}</CardMonoLabel>

      {
        isSingleRole && role ? (
          <>
            <CardTitle class="mt-0.5">{role.title}</CardTitle>

            <div class="mt-1 flex flex-wrap items-center gap-x-2.5 gap-y-1">
              <CardMetaDateRange
                startDate={role.dateRange.startDate}
                endDate={role.dateRange.endDate}
                noEndDateLabel="Present"
              />
              {role.employmentType && (
                <>
                  <MetaSeparator class="text-muted-foreground/70 text-xs lg:text-xs" />
                  <CardMetaEmploymentType
                    employmentType={role.employmentType}
                  />
                </>
              )}
              {role.location && (
                <>
                  <MetaSeparator class="text-muted-foreground/70 text-xs lg:text-xs" />
                  <CardMetaLocation location={role.location} />
                </>
              )}
            </div>

            <CardPills
              repositoryLinks={role.repositoryLinks}
              deploymentLinks={role.deploymentLinks}
              class="z-40 mt-2"
            />

            <CardDescription class="mt-2 whitespace-pre-line">
              {experience.companySummary}
            </CardDescription>
          </>
        ) : (
          <>
            <div class="mt-0.5">
              <div class="relative">
                <div class="border-muted-foreground/25 pointer-events-none absolute top-1 bottom-1 left-[7.5px] border-l sm:left-[11.5px]"></div>
                <ul class="flex flex-col gap-4">
                  {experience.roles.map((experienceRole) => (
                    <li class="group/role relative pl-6 sm:pl-8">
                      <div class="bg-primary ring-card pointer-events-none absolute top-2 left-2 z-10 size-3.5 -translate-x-1/2 rounded-full ring-4 sm:left-3" />

                      <CardTitle as="h3" hoverScope="role" class="gap-1.5">
                        {experienceRole.title}
                      </CardTitle>

                      <div class="mt-1 flex flex-wrap items-center gap-x-2.5 gap-y-1">
                        <CardMetaDateRange
                          startDate={experienceRole.dateRange.startDate}
                          endDate={experienceRole.dateRange.endDate}
                          noEndDateLabel="Present"
                        />
                        {experienceRole.employmentType && (
                          <>
                            <MetaSeparator class="text-muted-foreground/70 text-xs lg:text-xs" />
                            <CardMetaEmploymentType
                              employmentType={experienceRole.employmentType}
                            />
                          </>
                        )}
                        {experienceRole.location && (
                          <>
                            <MetaSeparator class="text-muted-foreground/70 text-xs lg:text-xs" />
                            <CardMetaLocation
                              location={experienceRole.location}
                            />
                          </>
                        )}
                      </div>

                      <CardPills
                        repositoryLinks={experienceRole.repositoryLinks}
                        deploymentLinks={experienceRole.deploymentLinks}
                        class="relative z-40 mt-2"
                      />

                      <a
                        href={`/experiences/${experienceRole.slug.current}`}
                        aria-label={`Link to ${experienceRole.title}`}
                        class="absolute inset-0 z-20"
                      />
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <CardDescription class="mt-3 whitespace-pre-line">
              {experience.companySummary}
            </CardDescription>
          </>
        )
      }
    </div>
  </div>
</article>
