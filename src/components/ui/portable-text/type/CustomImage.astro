---
import type { Props as $, TypedObject } from "astro-portabletext/types";
import ZoomableImage from "@/components/ui/image/zoomable-image.astro";

type Props = $<TypedObject> & {
  node: {
    url: string;
    alt: string;
    caption: boolean;
    maxWidth?:
      | "full"
      | "max-w-3xs"
      | "max-w-2xs"
      | "max-w-xs"
      | "max-w-sm"
      | "max-w-md"
      | "max-w-lg"
      | "max-w-xl"
      | "max-w-2xl"
      | "max-w-3xl";
  };
};

const props = Astro.props;
const maxWidth = props.node.maxWidth ?? "full";
const maxWidthClassMap = {
  full: "",
  "max-w-3xs": "max-w-3xs",
  "max-w-2xs": "max-w-2xs",
  "max-w-xs": "max-w-xs",
  "max-w-sm": "max-w-sm",
  "max-w-md": "max-w-md",
  "max-w-lg": "max-w-lg",
  "max-w-xl": "max-w-xl",
  "max-w-2xl": "max-w-2xl",
  "max-w-3xl": "max-w-3xl",
} as const;
const imageSizesMap = {
  full: "(max-width: 1023px) 100vw, 768px",
  "max-w-3xs": "(max-width: 1023px) 100vw, 256px",
  "max-w-2xs": "(max-width: 1023px) 100vw, 288px",
  "max-w-xs": "(max-width: 1023px) 100vw, 320px",
  "max-w-sm": "(max-width: 1023px) 100vw, 384px",
  "max-w-md": "(max-width: 1023px) 100vw, 448px",
  "max-w-lg": "(max-width: 1023px) 100vw, 512px",
  "max-w-xl": "(max-width: 1023px) 100vw, 576px",
  "max-w-2xl": "(max-width: 1023px) 100vw, 672px",
  "max-w-3xl": "(max-width: 1023px) 100vw, 768px",
} as const;
const figureClass = `w-full ${maxWidthClassMap[maxWidth]}`.trim();
const imageSizes = imageSizesMap[maxWidth];
---

<div class="mb-5 flex justify-center lg:mb-6">
  <figure class={figureClass}>
    {
      /* Max image width is container width, image height will adjust according to original aspect ratio */
    }
    <div class="border-border bg-muted overflow-hidden rounded-lg border">
      <ZoomableImage
        class="bg-muted text-muted-foreground flex h-auto w-full items-center justify-evenly rounded-lg object-cover object-center text-base font-medium"
        src={props.node.url}
        alt={props.node.alt}
        widths={[576, 768, 1152, 1280, 1440]}
        sizes={imageSizes}
        inferSize
      />
    </div>

    {
      props.node.caption && (
        <figcaption class="text-muted-foreground mt-1 px-3 text-center text-base font-medium lg:mt-2 lg:px-4 lg:text-lg">
          {props.node.alt}
        </figcaption>
      )
    }
  </figure>
</div>
