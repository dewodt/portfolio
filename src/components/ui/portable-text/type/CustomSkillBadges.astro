---
import type { Props as $, TypedObject } from "astro-portabletext/types";
import SkillBadge from "@/components/ui/badge/SkillBadge.astro";

type Skill = {
  _id: string;
  title: string;
  url: string;
  logoLight: string;
  logoDark: string;
};

type Props = $<TypedObject> & {
  node: {
    skills?: Array<Skill | null>;
  };
};

const { node } = Astro.props;
const skills = (node.skills ?? []).filter((skill): skill is Skill =>
  Boolean(skill),
);
---

{
  // uses mt-3 to add spacing
  skills.length > 0 && (
    <div class="mt-3 mb-6 lg:mb-7">
      <ul class="flex flex-row flex-wrap gap-2.5">
        {skills.map((skill) => (
          <li>
            <SkillBadge skill={skill} />
          </li>
        ))}
      </ul>
    </div>
  )
}
