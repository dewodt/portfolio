---
import DetailAdjacentNavigation from "@/components/ui/detail/DetailAdjacentNavigation.astro";
import DetailBack from "@/components/ui/detail/DetailBack.astro";
import DetailCompany from "@/components/ui/detail/DetailCompany.astro";
import DetailDateRange from "@/components/ui/detail/DetailDateRange.astro";
import DetailDescription from "@/components/ui/detail/DetailDescription.astro";
import DetailEmploymentType from "@/components/ui/detail/DetailEmploymentType.astro";
import DetailImage from "@/components/ui/detail/DetailImage.astro";
import DetailLocation from "@/components/ui/detail/DetailLocation.astro";
import DetailMonoLabel from "@/components/ui/detail/DetailMonoLabel.astro";
import DetailTitle from "@/components/ui/detail/DetailTitle.astro";
import Divider from "@/components/ui/Divider.astro";
import PillDeployment from "@/components/ui/pill/PillDeployment.astro";
import PillRepository from "@/components/ui/pill/PillRepository.astro";
import CustomPortableText from "@/components/ui/portable-text/CustomPortableText.astro";
import MetaSeparator from "@/components/ui/shared/MetaSeparator.astro";
import {
  allExperienceCompaniesQuery,
  experienceRoleDetailQuery,
  sanityClient,
} from "@/lib/query";
import LayoutBase from "@/layouts/LayoutBase.astro";
import type {
  AllExperienceCompaniesQueryResult,
  ExperienceRoleDetailQueryResult,
} from "@/types/sanity";

interface AdjacentExperienceRole {
  description: string;
  href: string;
  title: string;
}

export const getStaticPaths = async () => {
  const allExperienceCompanies =
    await sanityClient.fetch<AllExperienceCompaniesQueryResult>(
      allExperienceCompaniesQuery,
    );

  const orderedExperienceRoles = allExperienceCompanies.flatMap(
    (experienceCompany) =>
      experienceCompany.roles.map((role) => ({
        description: experienceCompany.companySummary,
        href: `/experiences/${role.slug.current}`,
        slug: role.slug.current,
        title: `${role.title} at ${experienceCompany.company}`,
      })),
  );

  return orderedExperienceRoles.map((role, index) => ({
    props: {
      next: orderedExperienceRoles[index + 1],
      previous: orderedExperienceRoles[index - 1],
    },
    params: {
      slug: role.slug,
    },
  }));
};

const experienceRoleDetailData =
  await sanityClient.fetch<ExperienceRoleDetailQueryResult>(
    experienceRoleDetailQuery,
    { slug: Astro.params.slug },
  );

if (!experienceRoleDetailData) {
  throw new Error("Experience role data not found");
}

const { company } = experienceRoleDetailData;
const { next, previous } = Astro.props as {
  next?: AdjacentExperienceRole;
  previous?: AdjacentExperienceRole;
};

const repositoryLinks = experienceRoleDetailData.repositoryLinks ?? [];
const deploymentLinks = experienceRoleDetailData.deploymentLinks ?? [];
const hasExperienceLinks = repositoryLinks.length + deploymentLinks.length > 0;
---

<LayoutBase
  title={`${experienceRoleDetailData.title} at ${company.name} | Dewantoro Triatmojo`}
  description={company.summary}
  linkPreviewImage={company.image}
>
  <main class="flex flex-auto justify-center px-5 py-10 sm:p-12 lg:p-14">
    <div class="flex w-full max-w-xl flex-col gap-6 lg:max-w-3xl lg:gap-8">
      <div class="animate-fade-in-up" style="animation-delay: 0.05s;">
        <DetailBack href="/experiences" label="Back to Experiences" />
      </div>

      <article class="flex flex-col gap-6 lg:gap-8">
        <div
          class="border-border bg-muted animate-fade-in-scale relative overflow-hidden rounded-xl border"
          style="animation-delay: 0.1s;"
        >
          <DetailImage
            src={experienceRoleDetailData.company.image.url!}
            alt={experienceRoleDetailData.company.image.alt}
          />
          <div
            class="from-background/40 pointer-events-none absolute inset-0 bg-linear-to-t via-transparent to-transparent"
          >
          </div>
        </div>

        <header class="flex flex-col">
          <div class="animate-fade-in-up" style="animation-delay: 0.15s;">
            <DetailMonoLabel
              >{experienceRoleDetailData.detailMonoLabel}</DetailMonoLabel
            >
          </div>

          <div
            class="animate-fade-in-up mt-1 lg:mt-2"
            style="animation-delay: 0.2s;"
          >
            <DetailTitle>{experienceRoleDetailData.title}</DetailTitle>
          </div>

          <div
            class="animate-fade-in-up mt-2 lg:mt-3"
            style="animation-delay: 0.25s;"
          >
            <div class="flex flex-wrap items-center gap-3">
              <DetailCompany company={company.name} />
              <MetaSeparator class="text-muted-foreground text-xs lg:text-sm" />
              <DetailDateRange
                dateRange={experienceRoleDetailData.dateRange}
                showPresentForEmptyEndDate={true}
              />
              {
                experienceRoleDetailData.employmentType && (
                  <>
                    <MetaSeparator class="text-muted-foreground text-xs lg:text-sm" />
                    <DetailEmploymentType
                      employmentType={experienceRoleDetailData.employmentType}
                    />
                  </>
                )
              }
              {
                experienceRoleDetailData.location && (
                  <>
                    <MetaSeparator class="text-muted-foreground text-xs lg:text-sm" />
                    <DetailLocation
                      location={experienceRoleDetailData.location}
                    />
                  </>
                )
              }
            </div>
            {
              hasExperienceLinks && (
                <div class="mt-2 flex flex-wrap items-center gap-3 lg:mt-3">
                  {repositoryLinks.map((repo) => (
                    <PillRepository repository={repo} />
                  ))}
                  {deploymentLinks.map((deploy) => (
                    <PillDeployment deployment={deploy} />
                  ))}
                </div>
              )
            }
          </div>

          <div
            class="animate-fade-in-up mt-2 lg:mt-3"
            style="animation-delay: 0.3s;"
          >
            <DetailDescription>
              {company.summary}
            </DetailDescription>
          </div>
        </header>

        <div class="animate-fade-in-up" style="animation-delay: 0.35s;">
          <Divider />
        </div>

        <section
          class="animate-fade-in-up w-full"
          style="animation-delay: 0.4s;"
        >
          {
            (
              // @ts-ignore
              <CustomPortableText value={experienceRoleDetailData.content} />
            )
          }
        </section>

        <div class="animate-fade-in-up" style="animation-delay: 0.45s;">
          <Divider />
        </div>

        <div class="animate-fade-in-up" style="animation-delay: 0.5s;">
          <DetailAdjacentNavigation previous={previous} next={next} />
        </div>
      </article>
    </div>
  </main>
</LayoutBase>
